{
    "_version": "1.37.0",
    "sap.app": {
        "id": "zmanagehamper",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.2"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.9.7",
            "toolsId": "62f192de-f91b-4a3c-8b61-c561b7acfdee"
        },
        "dataSources": {
            "mainService": {
                "uri": "/sap/opu/odata/sap/ZSOP_STORE_HAMPER_UI5_SRV/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "localUri": "localService/metadata.xml",
                    "odataVersion": "2.0"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "fullWidth": true,
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "dependencies": {
            "minUI5Version": "1.96.16",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.f": {},
                "sap.suite.ui.generic.template": {},
                "sap.ui.comp": {},
                "sap.ui.generic.app": {},
                "sap.ui.table": {},
                "sap.ushell": {},
                "sap.ndc": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "services": {
            "ShellUIService": {
                "factoryName": "sap.ushell.ui5service.ShellUIService"
            }
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "zmanagehamper.i18n.i18n"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "defaultBindingMode": "TwoWay",
                    "defaultCountMode": "Inline",
                    "refreshAfterChange": false
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "zmanagehamper.view",
                "controlAggregation": "pages",
                "controlId": "app",
                "clearControlAggregation": false,
                "bypassed": {
                    "target": [
                        "notFound"
                    ]
                }
            },
            "routes": [
                {
                    "name": "RouteHamperList",
                    "pattern": ":?query:",
                    "target": [
                        "TargetHamperList"
                    ]
                },
                {
                    "pattern": "HamperDetails/{HamperNo}/{BomId}",
                    "name": "HamperDetails",
                    "target": [
                        "TargetHamperDetails"
                    ]
                },
                {
                    "pattern": "HamperEdit",
                    "name": "HamperEdit",
                    "target": [
                        "TargetHamperEdit"
                    ]
                }
            ],
            "targets": {
                "TargetHamperList": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "HamperList",
                    "viewName": "HamperList"
                },
                "TargetHamperDetails": {
                    "viewName": "HamperDetails",
                    "viewId": "HamperDetails",
                    "viewLevel": 2
                },
                "TargetHamperEdit": {
                    "viewName": "HamperEdit",
                    "viewId": "HamperEdit",
                    "viewLevel": 2
                },
                "objectNotFound": {
                    "viewName": "ObjectNotFound",
                    "viewId": "objectNotFound"
                },
                "notFound": {
                    "viewName": "NotFound",
                    "viewId": "notFound"
                }
            }
        },
        "rootView": {
            "viewName": "zmanagehamper.view.App",
            "type": "XML",
            "async": true,
            "id": "App"
        }
    }
}